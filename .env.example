# Copy to `.env` or `.env.local` and replace placeholder values.
# Never commit real secrets.

# --- App ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Database (Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Optional: only for prisma/scripts/grant-sequences.mjs
# DATABASE_ADMIN_URL=
# APP_DB_USER=

# --- Auth (NextAuth v5 / Auth.js) ---
AUTH_SECRET=generate_a_long_random_string
# Optional fallback used by middleware:
# NEXTAUTH_SECRET=

# Public site URL for OAuth callbacks (production behind nginx — set explicitly):
# AUTH_URL=https://your-domain.com
# Or: AUTH_TRUST_HOST=true

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Payram (Add Funds → Pay with Payram; POST api.payram.com/v1/checkout) ---
# Required for Payram checkout. Name must match code: PAYRAM_SECRET_KEY (underscores, not hyphens).
PAYRAM_SECRET_KEY=your_payram_api_secret_here

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# LIVE or other (see code): switches sandbox vs live
PAYMENT_STATUS=LIVE

# --- BitPay ---
BITPAY_MERCHANT_ID=
BITPAY_PRIVATE_KEY=

# --- UploadThing (uploads / sign-up images) ---
# Use the token/secret from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=
# Some setups use UPLOADTHING_SECRET instead — match UploadThing docs.

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# --- Optional: profile API (expensive percentile; leave unset = off) ---
# PROFILE_INCLUDE_PERCENTILE=true
# SKIP_PROFILE_PERCENTILE=true
