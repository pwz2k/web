datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id                       String             @id @default(cuid())
  name                     String?
  email                    String?            @unique
  username                 String?            @unique
  image                    String?
  gender                   Gender?
  dateOfBirth              DateTime?
  location                 String?
  bio                      String?            @db.Text
  sexualOrientation        SexualOrientation?
  anonymous                Boolean            @default(false)
  sent_email_notifications Boolean            @default(true)

  // New voting-related fields
  isVerified         Boolean       @default(false)
  activityScore      Float         @default(0)
  votingPattern      VotingPattern @default(NEUTRAL)
  averageRatingGiven Float?
  totalVotesGiven    Int           @default(0)
  lastVoteTime       DateTime?

  // User engagement metrics
  commentCount Int      @default(0)
  photoCount   Int      @default(0)
  totalSpent   Int      @default(0)
  lastActiveAt DateTime @default(now())
  votingStreak Int      @default(0)

  // Existing fields
  emailVerified     DateTime? @default(now())
  password          String?
  role              UserRole  @default(USER)
  balance           Int       @default(0)
  commissionPercent Int       @default(20)
  banned            Boolean   @default(false)
  suspended         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts        Account[]
  post            Post[]
  vote            Vote[]
  comment         Comment[]
  Reports         Reports[]
  Transactions    Transactions[]
  Tipper          Tip[]             @relation("tipper")
  Creator         Tip[]             @relation("creator")
  activityLog     UserActivityLog[]
  PayoutMethod    PayoutMethod[]
  UserMilestone   UserMilestone[]
  Notification    Notification[]
  PostImpression  PostImpression[]
  ReportUpdateLog ReportUpdateLog[]
 @@map("User")
}

model UserActivityLog {
  id         String   @id @default(cuid())
  userId     String
  actionType String
  details    Json?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Post {
  id             String         @id @default(cuid())
  caption        String?
  tags           String?
  image          String
  approvalStatus ApprovalStatus @default(PENDING)

  // voting-related fields
  averageRating      Float @default(0)
  totalVotes         Int   @default(0)
  weightedRating     Float @default(0)
  ratingDistribution Json? // Store distribution of ratings

  impressions Int @default(0)
  sharesCount Int @default(0)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vote           Vote[]
  comment        Comment[]
  Reports        Reports[]
  Tip            Tip[]
  PostImpression PostImpression[]

  @@map("Post")
}

model PostImpression {
  id        String   @id @default(cuid())
  postId    String
  userId    String? // Null for anonymous users
  sessionId String? // For tracking anonymous users
  viewedAt  DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([sessionId])
  @@index([viewedAt])
}

model Vote {
  id        Int     @id @default(autoincrement())
  rating    Int
  weight    Float // Final calculated weight
  postId    String
  voterId   String?
  ipAddress String?

  // New fields for voting algorithm
  deviceId    String? // For duplicate prevention
  voteContext VoteContext @default(DIRECT)
  isOutlier   Boolean     @default(false)

  // Weight calculation components
  baseWeight    Float @default(1.0)
  userWeight    Float @default(1.0)
  contextWeight Float @default(1.0)

  // Demographic context
  voterAge    Int?
  voterGender Gender?

  post  Post  @relation(fields: [postId], references: [id])
  voter User? @relation(fields: [voterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, voterId, ipAddress])
  @@index([createdAt])
  @@map("Vote")
}

model ModeratorApplication {
  id Int @id @default(autoincrement())

  firstName            String
  lastName             String
  email                String
  profileLink          String
  gender               Gender
  age                  Int
  location             String
  dedicatedTimePerWeek Int
  moderatorStatement   String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("moderator_applications")
}

model Comment {
  id      String @id @default(cuid())
  content String
  postId  String
  userId  String

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("Comment")
}

model Reports {
  id     String @id @default(cuid())
  reason String

  postId String
  userId String

  status ApprovalStatus @default(PENDING)

  additionalInfo String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post            Post              @relation(fields: [postId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  faqs            FAQ[]
  ReportUpdateLog ReportUpdateLog[]
  @@map("reports")
}

model ReportUpdateLog {
  id String @id @default(cuid())

  comment String @db.Text

  // Relations
  reportId String
  report   Reports @relation(fields: [reportId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reportId String
  report   Reports @relation(fields: [reportId], references: [id])
}

model Transactions {
  id          String          @id @default(cuid())
  amount      Int
  description String?
  type        TransactionType

  status TransactionStatus @default(PENDING)

  commissionPercent Int?
  commissionAmount  Int?

  method     AvailablePayoutMethods
  identifier String?

  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  WebhookLogs WebhookLogs[]
  @@map("transactions")

}

model Tip {
  id        String @id @default(cuid())
  amount    Int
  postId    String
  userId    String
  creatorId String

  post    Post @relation(fields: [postId], references: [id])
  user    User @relation("tipper", fields: [userId], references: [id])
  creator User @relation("creator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("tips")

}

model PayoutMethod {
  id         String                 @id @default(cuid())
  method     AvailablePayoutMethods
  identifier String

  userId String

  user   User   @relation(fields: [userId], references: [id])
  @@map("payout_methods")

}

model Milestone {
  id          String        @id @default(cuid())
  name        String
  description String
  type        MilestoneType
  threshold   Int // Value required to achieve the milestone

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  UserMilestones UserMilestone[]
  @@map("milestones")

}

model UserMilestone {
  id          String   @id @default(cuid())
  userId      String
  milestoneId String
  achievedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  milestone Milestone @relation(fields: [milestoneId], references: [id])

  @@unique([userId, milestoneId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  userId    String
  title     String
  message   String           @db.Text
  data      Json? // Additional data specific to notification type
  isRead    Boolean          @default(false)
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WebhookLogs {
  id            String   @id @default(cuid())
  provider      String // Payment provider (e.g., "BITPAY")
  eventType     String // Type of event (e.g., "invoice_completed")
  transactionId String? // Optional reference to transaction
  rawPayload    String   @db.Text // Full webhook payload as JSON string
  processedAt   DateTime // When the webhook was processed
  success       Boolean // Whether processing was successful
  errorDetails  String?  @db.Text // Error details if processing failed
  ipAddress     String? // IP address of the sender (optional)
  headers       Json? // Request headers (optional)
  responseCode  Int? // HTTP response code sent back

  // Optional relation to your transactions table
  transaction Transactions? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, eventType])
  @@index([transactionId])
  @@index([success])
  @@index([processedAt])
}

model Contact {
  id          String         @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  inquiryType InquiryType
  subject     String
  message     String         @db.Text
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ENUMS

enum Gender {
  MALE
  FEMALE
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum SexualOrientation {
  STRAIGHT
  GAY
  BISEXUAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionStatus {
  COMPLETED
  PENDING
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  REFUND
}

// Add voting pattern and vote context enums
enum VotingPattern {
  NEUTRAL
  LOW_VOTER // Tends to vote 1-5
  HIGH_VOTER // Tends to vote 9-10
}

enum VoteContext {
  DIRECT
  REFERRAL
}

enum AvailablePayoutMethods {
  PAYPAL
  ZELLE
  VENMO
  STRIPE
  BTC
  ETH
  LITECOIN
  USDC_ERC_20
  CARDANO_ON_ADA_NETWORK
  POLYGON
  XRP
  TETHER
  DOGECOIN
}

enum MilestoneType {
  CASH_OUT
  EARNINGS
  VOTE_COUNT
  COMMENT_COUNT
  PHOTO_COUNT
  LOGIN_STREAK
  VOTING_STREAK
}

enum NotificationType {
  PHOTO_APPROVED
  PENDING_APPROVAL
  PHOTO_REJECTED
  PAYOUT_REQUEST
  TIP_RECEIVED
  TRANSACTION_COMPLETED
  TRANSACTION_REJECTED
}

enum InquiryType {
  GENERAL
  SUPPORT
  FEEDBACK
  PARTNERSHIP
  BILLING
  OTHER
}
